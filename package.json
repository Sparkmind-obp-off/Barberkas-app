{
  "name": "barberkas-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=barberkas-app-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "deploy": "npm run build && wrangler pages deploy dist --project-name barberkas-app",
    "db:migrate:local": "wrangler d1 migrations apply barberkas-app-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply barberkas-app-production",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000/health"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@eslint/js": "^9.9.0",
    "@hono/vite-build": "^1.11.1",
    "eslint": "^9.9.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "wrangler": "^3.78.0"
  }
}
